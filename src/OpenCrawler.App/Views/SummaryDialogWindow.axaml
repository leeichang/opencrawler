<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:OpenCrawler.App.Markup"
        xmlns:vm="using:OpenCrawler.App.ViewModels"
        x:Class="OpenCrawler.App.Views.SummaryDialogWindow"
        x:DataType="vm:SummaryDialogViewModel"
        Title="{loc:Tr Key=Articles_Summarize}"
        Width="720" Height="640"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Margin="16">

        <TextBlock Grid.Row="0" Text="{Binding ArticleTitle}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />

        <StackPanel Grid.Row="1" Spacing="4" Margin="0,12,0,0">
            <TextBlock Text="Prompt (episodeFocus)" FontWeight="SemiBold" />
            <TextBox Text="{Binding EpisodeFocus, Mode=TwoWay}"
                     AcceptsReturn="True"
                     Height="100"
                     TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
            <CheckBox Content="包含註解" IsChecked="{Binding IncludeNotes, Mode=TwoWay}" />
            <CheckBox Content="產生音訊摘要" IsChecked="{Binding GenerateAudio, Mode=TwoWay}" />
            <CheckBox Content="產生文字摘要 (Gemini)" IsChecked="{Binding GenerateText, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
            <Button Content="開始" Command="{Binding RunCommand}" IsEnabled="{Binding !IsRunning}" Classes="accent" />
            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" />
        </StackPanel>

        <TextBox Grid.Row="4"
                 Text="{Binding TextSummary, Mode=OneWay}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Margin="0,12,0,0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <TextBlock Text="Audio: " VerticalAlignment="Center" />
            <TextBlock Text="{Binding AudioUrl}" VerticalAlignment="Center"
                       Foreground="SteelBlue" />
            <Button Content="{loc:Tr Key=Common_Ok}" HorizontalAlignment="Right" Click="OnClose" />
        </StackPanel>
    </Grid>
</Window>
